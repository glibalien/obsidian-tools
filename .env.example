# Obsidian Tools Configuration
# Copy this to .env and update with your paths

# Path to your Obsidian vault
VAULT_PATH=~/Documents/your-vault-name

# Path to ChromaDB database (relative to project root, or absolute)
CHROMA_PATH=./.chroma_db

# Fireworks API key (used by the LLM agent)
FIREWORKS_API_KEY=your-api-key-here

# Fireworks model ID (default: gpt-oss-120b)
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b

# API server port
API_PORT=8000

# Vault indexer interval in minutes
INDEX_INTERVAL=60

# --- Optional (uncomment to override defaults) ---

# Fireworks API base URL
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Indexing
# INDEX_WORKERS=4              # Thread pool size for parallel file indexing
# UPSERT_BATCH_SIZE=500        # Chunks per ChromaDB upsert batch
# EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5  # Sentence-transformers embedding model

# Search pipeline
# RERANK_MODEL=BAAI/bge-reranker-v2-m3  # Cross-encoder model for result reranking
# RERANK_ENABLED=true          # Toggle cross-encoder reranking
# MAX_CHUNKS_PER_SOURCE=3      # Max chunks per source file in results (0 = disabled)
# HYDE_ENABLED=true             # Toggle HyDE for question-type queries

# File readers
# WHISPER_MODEL=whisper-v3                                          # Audio transcription model
# VISION_MODEL=accounts/fireworks/models/qwen3-vl-30b-a3b-instruct # Image description model

# AI tools
# SUMMARIZE_MODEL=             # Summarization model (defaults to FIREWORKS_MODEL)
# RESEARCH_MODEL=              # Research pipeline model (defaults to FIREWORKS_MODEL)
# MAX_RESEARCH_TOPICS=10       # Max topics extracted per note
# MAX_PAGE_CHARS=50000         # Safety cap for fetched web page content
# PAGE_FETCH_TIMEOUT=10        # Seconds per web page fetch

# Logging
# LOG_DIR=                     # Default: VAULT_PATH/logs/
# LOG_MAX_BYTES=5242880        # 5 MB
# LOG_BACKUP_COUNT=3

# API session limits
# MAX_SESSIONS=20              # Max concurrent sessions (LRU eviction)
# MAX_SESSION_MESSAGES=50      # Max messages per session (oldest trimmed)
